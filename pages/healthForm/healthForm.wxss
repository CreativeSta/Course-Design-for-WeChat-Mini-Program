page {
  background: #f4f6fa;
}

.health-page {
  padding: 24rpx;
}

.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
}

.page-subtitle {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.panel {
  margin-top: 18rpx;
  background: #ffffff;
  border-radius: 22rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.08);
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 30rpx;
  color: #111827;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.input {
  height: 84rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #1f2937;
  box-sizing: border-box;
  background: #ffffff;
}

.input:focus {
  border-color: #2563eb;
}

.radio-row {
  display: flex;
  gap: 34rpx;
}

.radio-option {
  font-size: 30rpx;
  color: #1f2937;
  display: flex;
  align-items: center;
}

.bp-row {
  display: flex;
  align-items: center;
}

.half {
  width: 45%;
}

.split {
  width: 10%;
  text-align: center;
  font-size: 32rpx;
  color: #6b7280;
}

.disease-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 20rpx;
}

.disease-option {
  min-width: 42%;
  font-size: 28rpx;
  color: #374151;
  display: flex;
  align-items: center;
}

.error-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #dc2626;
}

radio,
checkbox {
  transform: scale(1.2);
  margin-right: 12rpx;
}

.action-buttons {
  margin-top: 10rpx;
  display: flex;
  gap: 14rpx;
}

.reset-btn,
.submit-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  line-height: 90rpx;
}

.reset-btn {
  background: #e5e7eb;
  color: #1f2937;
}

.submit-btn {
  background: #2563eb;
  color: #ffffff;
}

.submit-btn[disabled] {
  background: #93c5fd;
  color: #e5edff;
}
