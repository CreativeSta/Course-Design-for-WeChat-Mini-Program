/* product.wxss - 适老化优化 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.product-item {
  width: 48%;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  transition: all 0.2s;
}

.product-item:active {
  background-color: #f5f5f5;
  transform: scale(0.98);
}

.product-image {
  width: 220rpx;
  height: 220rpx;
  margin: 0 auto 25rpx;
  border-radius: 12rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  line-height: 1.4;
}

.product-price {
  font-size: 28rpx;
  color: #e64340;
  margin-top: 10rpx;
  margin-bottom: 15rpx;
}

.add-to-cart {
  font-size: 26rpx;
  color: #ffffff;
  background-color: #e64340;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  margin: 0 auto;
  width: 200rpx;
}

.add-to-cart:active {
  background-color: #cc2926;
}

/* 购物车按钮样式 */
.cart-button {
  position: fixed;
  right: 40rpx;
  top: 140rpx;
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  border-radius: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  font-size: 28rpx;
  color: #333333;
  z-index: 999;
  display: flex;
  align-items: center;
}

.cart-badge {
  background-color: #e64340;
  color: #ffffff;
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  margin-left: 10rpx;
  min-width: 24rpx;
  text-align: center;
}

.back-home {
  position: fixed;
  right: 30rpx;
  bottom: 30rpx;
  z-index: 999;
}

.home-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}