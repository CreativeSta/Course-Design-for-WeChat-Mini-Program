/* login.wxss - 优化文本显示和适老化设计 */
/* 基础容器样式 */
.container {
  padding: 0 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0;
  background-color: #fff;
  margin: 20rpx 0 30rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
  transform: rotate(180deg);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.empty {
  width: 80rpx;
}

/* 登录表单 */
.login-form {
  background-color: #fff;
  padding: 50rpx 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 50rpx;
}

.label {
  font-size: 34rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
  font-weight: 500;
}

.input-container {
  position: relative;
  display: flex;
  align-items: center;
  /* 确保容器有足够空间 */
  height: 120rpx;
}

.prefix {
  position: absolute;
  left: 30rpx;
  font-size: 32rpx;
  color: #999;
  z-index: 1;
  line-height: 120rpx;
}

/* 输入框样式 - 重点优化文本显示 */
.input {
  border: 2rpx solid #ddd;
  border-radius: 15rpx;
  font-size: 34rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  /* 适老化设计：增大触摸区域和确保文本完整显示 */
  height: 120rpx !important;
  line-height: 120rpx !important;
  padding-left: 100rpx;
  /* 确保文本不被截断 */
  text-overflow: clip !important;
  overflow: visible !important;
  white-space: nowrap !important;
  /* 字体设置确保中文显示 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 为密码输入框移除左侧内边距 */
.form-item:nth-child(2) .input {
  padding-left: 30rpx !important;
}

/* 使用伪元素设置占位符样式 - 更可靠的方式 */
.input::placeholder {
  color: #999 !important;
  font-size: 34rpx !important;
  line-height: 120rpx !important;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important;
  text-overflow: clip !important;
  overflow: visible !important;
  white-space: nowrap !important;
}

/* 确保placeholder-class也能生效 */
.input-placeholder {
  color: #999 !important;
  font-size: 34rpx !important;
  line-height: 120rpx !important;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important;
  text-overflow: clip !important;
  overflow: visible !important;
  white-space: nowrap !important;
}

/* 密码可见性切换图标 */
.eye-icon {
  position: absolute;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-img {
  width: 40rpx;
  height: 40rpx;
}

/* 忘记密码链接 */
.forgot-password {
  font-size: 30rpx;
  color: #1aad19;
  text-align: right;
  margin-bottom: 60rpx;
  padding: 10rpx 0;
}

/* 登录按钮 */
.login-btn {
  font-size: 36rpx;
  padding: 35rpx;
  border-radius: 20rpx;
  background-color: #1aad19;
  color: #fff;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(26, 173, 25, 0.2);
}

.login-btn:active {
  background-color: #179616;
}

.wechat-entry {
  margin-top: 16rpx;
}

.wechat-divider {
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
  margin: 10rpx 0 16rpx;
}

.wechat-btn {
  font-size: 32rpx;
  padding: 26rpx;
  border-radius: 20rpx;
  background-color: #07c160;
  color: #ffffff;
}

/* 登录提示信息样式 */
.login-tip {
  margin-top: 30rpx;
  padding: 20rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #666;
  text-align: center;
  word-break: break-all;
}

/* 错误提示信息样式 */
.error-message {
  color: #e64340;
  font-size: 28rpx;
  margin-top: 10rpx;
  padding: 0 5rpx;
}

.error-tip {
  margin-top: 30rpx;
  padding: 20rpx;
  background-color: #fff1f0;
  border: 2rpx solid #ffccc7;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #e64340;
  text-align: center;
}

/* 适配小屏幕 */
@media screen and (max-width: 320px) {
  .container {
    padding: 0 30rpx;
  }
  
  .login-form {
    padding: 40rpx 30rpx;
  }
  
  .form-item {
    margin-bottom: 40rpx;
  }
  
  .input {
    font-size: 32rpx !important;
  }
  
  .input::placeholder {
    font-size: 32rpx !important;
  }
  
  .input-placeholder {
    font-size: 32rpx !important;
  }
}

/* 强制覆盖微信小程序默认样式 - 关键修复 */
input {
  height: 120rpx !important;
  line-height: 120rpx !important;
  font-size: 34rpx !important;
  text-overflow: clip !important;
  overflow: visible !important;
  white-space: nowrap !important;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important;
}

input::placeholder {
  font-size: 34rpx !important;
  line-height: 120rpx !important;
  color: #999 !important;
  text-overflow: clip !important;
  overflow: visible !important;
  white-space: nowrap !important;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important;
}

/* 针对微信小程序input组件的特殊处理 */
.input-container input {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* 确保容器有足够高度 */
.form-item {
  height: auto !important;
  min-height: 160rpx;
}

/* unified auth button size */
.auth-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 34rpx;
  font-weight: 600;
}

.auth-btn::after {
  border: none;
}

.login-btn {
  margin-bottom: 30rpx;
  background-color: #1aad19;
  color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(26, 173, 25, 0.2);
}

.wechat-btn {
  background-color: #1aad19;
  color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(26, 173, 25, 0.2);
}

.login-btn:active,
.wechat-btn:active {
  background-color: #179616;
}
