<!-- login.wxml -->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="onBack">
      <image src="/images/arrow-left.png" class="back-icon"></image>
    </view>
    <view class="title">登录</view>
    <view class="empty"></view>
  </view>

  <view class="login-form">
    <view class="form-item">
      <view class="label">手机号</view>
      <view class="input-container">
        <text class="prefix">+86</text>
        <input
          type="number"
          placeholder="请输入手机号"
          placeholder-class="input-placeholder"
          bindinput="onPhoneInput"
          value="{{phoneNumber}}"
          class="input"
          maxlength="11"
        />
      </view>
      <view class="error-message" wx:if="{{phoneError}}">{{phoneError}}</view>
    </view>

    <view class="form-item">
      <view class="label">密码</view>
      <view class="input-container">
        <input
          password="{{!showPassword}}"
          placeholder="请输入密码"
          placeholder-class="input-placeholder"
          bindinput="onPasswordInput"
          value="{{password}}"
          class="input"
        />
        <view class="eye-icon" bindtap="togglePasswordVisibility">
          <image src="{{showPassword ? '/images/eye-open.png' : '/images/eye-closed.png'}}" class="eye-img"></image>
        </view>
      </view>
      <view class="error-message" wx:if="{{passwordError}}">{{passwordError}}</view>
    </view>

    <view class="forgot-password" bindtap="onForgotPassword">忘记密码？</view>

    <button class="auth-btn login-btn" bindtap="onLogin" loading="{{isLoading}}" disabled="{{isLoading}}">
      {{isLoading ? '登录中...' : '登录'}}
    </button>

    <view class="wechat-entry">
      <view class="wechat-divider">或</view>
      <button class="auth-btn wechat-btn" bindtap="onWechatLogin" loading="{{isLoading}}" disabled="{{isLoading}}">
        微信一键登录
      </button>
    </view>

    <view class="login-tip" wx:if="{{showLoginTip && phoneNumber && password}}">
      <text>账号：{{phoneNumber}} 密码：{{password}}</text>
    </view>

    <view class="error-tip" wx:if="{{errorMsg}}">{{errorMsg}}</view>
  </view>
</view>
