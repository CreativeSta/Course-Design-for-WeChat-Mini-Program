<view class="container">
  <view class="knowledge-detail">
    <view class="knowledge-title">{{knowledge.title}}</view>
    
    <view class="knowledge-info">
      <text class="source">来源：{{knowledge.source}}</text>
    </view>
    
    <image src="{{knowledge.image}}" class="knowledge-image" mode="aspectFill"></image>
    
    <view class="knowledge-content">
      {{knowledge.content}}
    </view>
    
    <view class="knowledge-tips">
      <view class="tips-title">温馨提示</view>
      <text class="tips-text">本内容仅供参考，如有身体不适，请及时就医。</text>
    </view>
  </view>
  
  <!-- 返回按钮 -->
  <view class="back-button" bindtap="navigateBack">
    <image src="/images/arrow-left.png" class="back-icon"></image>
    <text>返回</text>
  </view>
</view>