/* medicalGuide.wxss */
.container {
  padding: 0 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 40rpx 0;
  text-align: center;
}

.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.img-fluid {
  width: 100%;
  height: auto;
  border-radius: 10rpx;
}

/* 步骤列表样式 */
.step-item {
  display: flex;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  /* 适老化设计：增大触摸区域 */
  padding-top: 40rpx;
  padding-bottom: 40rpx;
}

.step-item:last-child {
  border-bottom: none;
}

.step-number {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #e60012;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
  /* 适老化设计：增大尺寸 */
}

.step-content {
  flex: 1;
}

.step-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
  /* 适老化设计：增大字号 */
}

.step-desc {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.6;
  /* 适老化设计：增大字号和行高 */
}

/* 返回按钮样式 */
.back-btn {
  background-color: #e60012;
  color: #ffffff;
  border-radius: 40rpx;
  padding: 30rpx 60rpx;
  text-align: center;
  font-size: 36rpx;
  margin: 50rpx auto;
  width: 60%;
  /* 适老化设计：增大尺寸和圆角 */
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s;
}

.back-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  /* 适老化设计：触摸反馈 */
}

/* 医院小贴士样式 */
.tip-list {
  padding: 10rpx 0;
}

.tip-item {
  display: flex;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: flex-start;
}

.tip-item:last-child {
  border-bottom: none;
}

.tip-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 25rpx;
  background-color: #4CAF50;
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  margin-top: 5rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.tip-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

/* 常见科室样式 */
.department-list {
  padding: 10rpx 0;
}

.department-item {
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.department-item:last-child {
  border-bottom: none;
}

.department-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.department-desc {
  font-size: 28rpx;
  color: #666666;
}

/* 适配小屏幕 */
@media screen and (max-width: 320px) {
  .container {
    padding: 0 30rpx;
  }
  
  .card {
    padding: 30rpx;
  }
  
  .section-title {
    font-size: 34rpx;
    margin: 30rpx 0;
  }
  
  .back-btn {
    width: 80%;
    padding: 25rpx 40rpx;
    font-size: 32rpx;
  }
  
  .tip-item {
    padding: 20rpx 0;
  }
  
  .department-item {
    padding: 20rpx 0;
  }
}