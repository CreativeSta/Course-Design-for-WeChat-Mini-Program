.container {
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.medicine-detail {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.medicine-name {
  text-align: center;
  margin-bottom: 20rpx;
}

.chinese-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.latin-name {
  font-size: 28rpx;
  color: #999;
  font-style: italic;
}

.medicine-image {
  width: 100%;
  height: 400rpx;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
}

.medicine-info {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
  margin-bottom: 30rpx;
}

.info-item {
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #c8a97e;
  margin-bottom: 10rpx;
}

.info-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-line;
}

.medicine-tips {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 10rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  border-radius: 50rpx;
  margin: 40rpx auto;
  padding: 20rpx 40rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  width: 200rpx;
}

.back-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
}

.back-button text {
  color: #333;
  font-size: 28rpx;
}