/* 购物车页面样式 */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 120rpx; /* 为底部结算栏留出空间 */
}

.section-title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin: 30rpx 0;
  color: #333;
}

/* 空购物车样式 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 150rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 36rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-subtext {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-go-shopping {
  width: 240rpx;
  height: 80rpx;
  background-color: #07c160;
  color: #fff;
  text-align: center;
  line-height: 80rpx;
  font-size: 32rpx;
  border-radius: 10rpx;
}

/* 购物车列表样式 */
.cart-list {
  margin-top: 20rpx;
}

.cart-item {
  display: flex;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.product-price {
  font-size: 36rpx;
  color: #e64340;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.product-quantity {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  background-color: #f0f0f0;
  text-align: center;
  line-height: 60rpx;
  font-size: 40rpx;
  border-radius: 50%;
  margin: 0 10rpx;
}

.quantity {
  width: 80rpx;
  text-align: center;
  font-size: 32rpx;
}

.delete-btn {
  padding: 0 20rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #e64340;
  color: #fff;
  font-size: 32rpx;
  border-radius: 10rpx;
  align-self: center;
}

/* 底部结算栏样式 */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #e64340;
}

.btn-checkout {
  width: 200rpx;
  height: 80rpx;
  background-color: #07c160;
  color: #fff;
  text-align: center;
  line-height: 80rpx;
  font-size: 32rpx;
  border-radius: 10rpx;
}

/* 返回首页按钮样式 */
.back-home {
  position: fixed;
  bottom: 120rpx;
  right: 30rpx;
}

.home-icon {
  width: 80rpx;
  height: 80rpx;
}

/* 按钮点击效果 */
.btn-go-shopping:active,
.quantity-btn:active,
.delete-btn:active,
.btn-checkout:active {
  opacity: 0.8;
}