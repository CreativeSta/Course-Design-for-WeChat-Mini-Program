page {
  background: #f4f6fa;
}

.result-page {
  padding: 24rpx;
}

.header-card {
  background: linear-gradient(140deg, #2563eb 0%, #3b82f6 100%);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(37, 99, 235, 0.2);
}

.title {
  font-size: 38rpx;
  color: #ffffff;
  font-weight: 700;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.card {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 18rpx;
  padding: 22rpx;
  box-shadow: 0 5rpx 14rpx rgba(15, 23, 42, 0.07);
}

.card-title {
  font-size: 30rpx;
  color: #111827;
  font-weight: 700;
}

.summary-row {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.summary-item {
  flex: 1;
  border-radius: 12rpx;
  background: #f8fafc;
  padding: 14rpx 10rpx;
  text-align: center;
}

.summary-label {
  font-size: 22rpx;
  color: #6b7280;
}

.summary-value {
  margin-top: 6rpx;
  font-size: 30rpx;
  color: #111827;
  font-weight: 700;
}

.summary-level {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #2563eb;
}

.disease-line {
  margin-top: 14rpx;
  font-size: 25rpx;
  color: #374151;
}

.suggestion-item {
  margin-top: 12rpx;
  display: flex;
  align-items: flex-start;
}

.index {
  width: 34rpx;
  font-size: 25rpx;
  color: #2563eb;
  font-weight: 700;
}

.text {
  flex: 1;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

.history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.toggle {
  font-size: 24rpx;
  color: #2563eb;
}

.history-list {
  margin-top: 10rpx;
}

.history-item {
  border-top: 1rpx solid #e5e7eb;
  padding: 14rpx 0;
}

.history-time {
  font-size: 24rpx;
  color: #111827;
}

.history-data {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #6b7280;
}

.action-row {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
}

.ghost-btn,
.primary-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 30rpx;
}

.ghost-btn {
  background: #e5e7eb;
  color: #1f2937;
}

.primary-btn {
  background: #2563eb;
  color: #ffffff;
}

.empty-page {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 24rpx;
}

.empty-text {
  text-align: center;
  color: #6b7280;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}
