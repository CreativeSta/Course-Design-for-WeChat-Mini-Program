/* diseaseEducation.wxss */
.container {
  padding: 0 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 40rpx 0;
  text-align: center;
}

.disease-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.disease-card {
  display: flex;
  padding: 40rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
  align-items: center;
  transition: all 0.2s;
  /* 适老化设计：增大触摸区域 */
  padding-top: 50rpx;
  padding-bottom: 50rpx;
}

.disease-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  /* 适老化设计：触摸反馈 */
}

.disease-icon {
  width: 140rpx;
  height: 140rpx;
  margin-right: 40rpx;
  /* 适老化设计：增大图标尺寸 */
}

.disease-content {
  flex: 1;
}

.disease-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  /* 适老化设计：增大字号 */
}

.disease-desc {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.6;
  /* 适老化设计：增大字号和行高 */
}

/* 返回按钮样式 */
.back-btn {
  background-color: #e60012;
  color: #ffffff;
  border-radius: 40rpx;
  padding: 30rpx 60rpx;
  text-align: center;
  font-size: 36rpx;
  margin: 50rpx auto;
  width: 60%;
  /* 适老化设计：增大尺寸和圆角 */
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s;
}

.back-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  /* 适老化设计：触摸反馈 */
}

/* 适配小屏幕 */
@media screen and (max-width: 320px) {
  .container {
    padding: 0 30rpx;
  }
  
  .disease-card {
    padding: 30rpx;
    flex-direction: column;
    text-align: center;
  }
  
  .disease-icon {
    margin-right: 0;
    margin-bottom: 20rpx;
  }
  
  .section-title {
    font-size: 34rpx;
    margin: 30rpx 0;
  }
  
  .back-btn {
    width: 80%;
    padding: 25rpx 40rpx;
    font-size: 32rpx;
  }
}