/* service.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.service-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}

/* 服务卡片样式优化 */
.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 30rpx;
  transition: all 0.2s;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.card:active {
  background-color: #f0f0f0;
  transform: scale(0.98);
}

.img-fluid {
  width: 100%;
  height: 280rpx;
  border-radius: 10rpx;
}

.back-home {
  position: fixed;
  right: 30rpx;
  bottom: 30rpx;
  z-index: 999;
}

.home-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}
